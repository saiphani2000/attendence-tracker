# Flask Configuration
FLASK_APP=wsgi.py
FLASK_ENV=development

# Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# Database
DATABASE_URL=sqlite:///instance/student_tracker.db
# DATABASE_URL=postgresql://username:password@localhost:5432/student_tracker

# Gunicorn (optional)
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120

# Demo accounts (created on first startup if DB is empty):
# Teacher: demo@teacher.com / demo12345
# Student: john@student.com / student123
# Admin:   admin@school.com / admin12345
